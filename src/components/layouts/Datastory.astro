---
import { render, type CollectionEntry } from "astro:content";
import Lightbox from "../ui/Lightbox.astro";
import ScreenToggle from "../ui/ScreenToggle.astro";
import C2PAOverlay from "../ui/C2PAOverlay.astro";
import ContentsToggle from "../ui/ContentsToggle.astro";
import fs from "node:fs";
import path from "node:path";

interface Props {
  post: CollectionEntry<"datastory">;
}

const { post } = Astro.props;
const { Content } = await render(post);

const backgroundColor = post.data.backgroundColor || "var(--surface)";
const formattedDate = post.data.date?.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

let notebookHtml = "";
interface TocEntry { slug: string; text: string; }
const tocEntries: TocEntry[] = [];
let hasKatex = false;

const contentBase = path.resolve("src/content/datastory");
const htmlPath = path.join(contentBase, `${post.id}.notebook.html`);
if (fs.existsSync(htmlPath)) {
  notebookHtml = fs.readFileSync(htmlPath, "utf-8").trim();

  const h2Re = /<h2[^>]*id=["']([^"']*)["'][^>]*>(.*?)<\/h2>/gi;
  let match: RegExpExecArray | null;
  while ((match = h2Re.exec(notebookHtml)) !== null) {
    const slug = match[1];
    const text = match[2].replace(/<[^>]*>/g, "").replace(/\u00b6/g, "").trim();
    if (text) tocEntries.push({ slug, text });
  }

  hasKatex = /\$\$|\\\(|\\\[|\\begin\{|(^|[^$])\$[^\n$]+\$(?!\$)/.test(notebookHtml);
}
---

{hasKatex && (
  <>
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin="anonymous">
    <link rel="preload" as="style" href="https://cdn.jsdelivr.net/npm/katex@0.16.38/dist/katex.min.css" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.38/dist/katex.min.css" integrity="sha384-/L6i+LN3dyoaK2jYG5ZLh5u13cjdsPDcFOSNJeFBFa/KgVXR5kOfTdiN3ft1uMAq" crossorigin="anonymous">
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.38/dist/katex.min.js" integrity="sha384-H6s1ZrH2CKpFpqR680poRdStIRJGXty7fSkxAcIfxwl9iu6A4BOPtTk7vQ58Ovio" crossorigin="anonymous"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.38/dist/contrib/auto-render.min.js" integrity="sha384-bjyGPfbij8/NDKJhSGZNP/khQVgtHUE5exjm4Ydllo42FwIgYsdLO2lXGmRBf5Mz" crossorigin="anonymous"></script>
  </>
)}

<article class="datastory-layout" style={`--page-bg: ${backgroundColor};`}>
  <header class="post-header datastory-header">
    <div class="post-kicker">
      <span class="collection-type">Data Story</span>
    </div>
    <h1 class="post-title">{post.data.title}</h1>
    {post.data.subtitle && <p class="post-subtitle">{post.data.subtitle}</p>}
    <div class="post-author-line">
      <span class="by">By</span>
      <span class="author-name">{post.data.author}</span>
    </div>
    {formattedDate && (
      <div class="post-date-line">
        <time datetime={post.data.date?.toISOString()}>{formattedDate}</time>
      </div>
    )}
    {post.data.showhero !== false && post.data.heroImage && (
      <figure class="post-hero">
        <img src={post.data.heroImage} alt={post.data.title} />
      </figure>
    )}
  </header>

  <div class="datastory-container">
    {post.data.toc && tocEntries.length > 0 && (
      <ContentsToggle title={post.data.title}>
        <ul>
          {tocEntries.map((h) => (
            <li><a href={`#${h.slug}`}>{h.text}</a></li>
          ))}
        </ul>
      </ContentsToggle>
    )}

    <div class="datastory-prose">
      <Content />
    </div>

    {notebookHtml && (
      <div class="notebook-wrapper" set:html={notebookHtml} />
    )}
  </div>

  <Lightbox selector=".notebook-wrapper" gallery={post.data.lightbox?.gallery} />
  <ScreenToggle />
  <C2PAOverlay />
</article>

<script>
  function refineDatastoryContent() {
    const header = document.querySelector('.site-header') as HTMLElement;
    if (header) {
      header.style.backgroundColor = '#2a2a2a';
      header.style.transition = 'background-color 0.3s ease';
      const headerInner = header.querySelector('.site-header-inner') as HTMLElement;
      if (headerInner) headerInner.style.backgroundColor = 'transparent';
      header.querySelectorAll('a, button').forEach((el) => {
        (el as HTMLElement).style.color = '#fff';
      });
      header.querySelectorAll('.site-logo, .site-logo a').forEach((el) => {
        (el as HTMLElement).style.color = '#fff';
      });
    }
    document.body.classList.add('no-snow');
  }

  refineDatastoryContent();
  document.addEventListener('astro:page-load', refineDatastoryContent);

  function renderNotebookMath() {
    const wrapper = document.querySelector('.notebook-wrapper');
    if (!wrapper || typeof window.renderMathInElement !== 'function') return;
    window.renderMathInElement(wrapper as HTMLElement, {
      delimiters: [
        { left: "$$", right: "$$", display: true },
        { left: "$", right: "$", display: false },
        { left: "\\(", right: "\\)", display: false },
        { left: "\\[", right: "\\]", display: true },
      ],
      throwOnError: false,
    });
  }

  if (document.readyState === 'complete') {
    renderNotebookMath();
  } else {
    window.addEventListener('load', renderNotebookMath);
  }
  document.addEventListener('astro:page-load', () => {
    setTimeout(renderNotebookMath, 100);
  });
</script>

<style is:global>
  /* ── Layout shell ───────────────────────────────────────── */
  .datastory-layout {
    width: 100%;
    min-height: 100vh;
    background: var(--page-bg, var(--surface));
  }

  /* ════════════════════════════════════════════════════════
     PAGE HEADER — Data Journalism aesthetic
     Inspired by FT / The Atlantic: dark ruled band at top,
     mono kicker, tight condensed title, full-bleed hero.
     ════════════════════════════════════════════════════════ */
  .datastory-header {
    background: var(--paper);
    padding: 7rem 2rem 0;
    text-align: center;
    border-bottom: none;
  }

  /* Thin top rule above kicker — data-journalism signature */
  .datastory-header .post-kicker {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1.5rem;
    border-top: 3px solid #111;
    margin-bottom: 2rem;
  }

  .datastory-header .post-kicker .collection-type {
    font-family: "Inter", sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #fff;
    background: #111;
    padding: 0.2em 0.65em;
    border-radius: 2px;
  }

  /* Title: Inter tight-condensed — data, precision, authority */
  .datastory-header .post-title {
    font-family: "Inter", system-ui, sans-serif;
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.05em;
    line-height: 0.95;
    color: #0a0a0a;
    max-width: 18ch;
    margin: 0 auto 1.5rem;
  }

  /* Subtitle: serif italic — the editorial voice */
  .datastory-header .post-subtitle {
    font-family: "Fraunces", Georgia, serif;
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.5;
    color: rgba(0, 0, 0, 0.65);
    max-width: 55ch;
    margin: 0 auto 2rem;
  }

  /* Byline */
  .datastory-header .post-author-line {
    font-family: "Inter", sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: #555;
    margin-bottom: 0.4rem;
  }

  .datastory-header .post-author-line .by {
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    color: #999;
    margin-right: 0.4rem;
  }

  .datastory-header .post-author-line .author-name {
    color: #111;
    font-weight: 600;
  }

  /* Date */
  .datastory-header .post-date-line {
    font-family: "Inter", sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    color: #999;
    margin-bottom: 2.5rem;
  }

  /* Hero image: full-bleed, cinematic, no margins */
  .datastory-header .post-hero {
    margin: 0 -2rem;
    line-height: 0;
    max-width: none;
    width: calc(100% + 4rem);
  }

  .datastory-header .post-hero img {
    width: 100%;
    height: auto;
    display: block;
    max-height: 70vh;
    object-fit: cover;
  }

  /* ── Content container — single column, no wasted gutter ── */
  .datastory-container {
    width: min(960px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 3rem 0 5rem;
  }

  /* ── Notebook wrapper ───────────────────────────────────── */
  .notebook-wrapper {
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
    box-sizing: border-box;
    padding: 0 0.5rem;
  }

  /* ── Chart / plot images: constrain to column width ──────── */
  .notebook-wrapper .jp-RenderedImage img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  /* ── Hide Out[N]: prompt labels ─────────────────────────── */
  .notebook-wrapper .jp-OutputPrompt {
    display: none;
  }

  /* ── pre / code overflow ────────────────────────────────── */
  .notebook-wrapper pre {
    overflow-x: auto;
    white-space: pre;
  }

  /* ── Tables: sophisticated styling ─────────────────────────
     Natural min-width so content isn't crunched on mobile;
     horizontal scroll on the wrapper instead.
     ────────────────────────────────────────────────────────── */
  .notebook-wrapper .jp-RenderedHTMLCommon .dataframe-wrapper,
  .notebook-wrapper .jp-RenderedHTMLCommon {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .notebook-wrapper .jp-RenderedHTMLCommon table {
    border-collapse: collapse;
    border-spacing: 0;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.82rem;
    line-height: 1.5;
    color: #1a1a1a;
    width: auto;
    min-width: 500px;
    margin: 1.5rem 0;
    background: #fff;
  }

  .notebook-wrapper .jp-RenderedHTMLCommon thead {
    background: #0a0a0a;
    color: #fff;
  }

  .notebook-wrapper .jp-RenderedHTMLCommon thead th {
    padding: 0.6rem 1rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-align: left;
    border: none;
    white-space: nowrap;
    color: #fff;
  }

  .notebook-wrapper .jp-RenderedHTMLCommon tbody tr {
    border-bottom: 1px solid #e8e8e8;
    transition: background 0.1s;
  }

  .notebook-wrapper .jp-RenderedHTMLCommon tbody tr:nth-child(even) {
    background: #f8f8f8;
  }

  .notebook-wrapper .jp-RenderedHTMLCommon tbody tr:hover {
    background: #f0f4ff;
  }

  .notebook-wrapper .jp-RenderedHTMLCommon tbody td {
    padding: 0.5rem 1rem;
    border: none;
    text-align: left;
    vertical-align: top;
    color: #2a2a2a;
  }

  /* Row index column — subtle, muted */
  .notebook-wrapper .jp-RenderedHTMLCommon tbody th {
    padding: 0.5rem 0.75rem;
    border: none;
    font-weight: 400;
    color: #999;
    font-size: 0.78rem;
    background: transparent;
    text-align: right;
    border-right: 1px solid #e8e8e8;
  }

  /* Outer border */
  .notebook-wrapper .jp-RenderedHTMLCommon table {
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    overflow: hidden;
  }

  /* ── Notebook prose typography ──────────────────────────── */
  .notebook-wrapper .jp-RenderedMarkdown p,
  .notebook-wrapper .jp-RenderedHTMLCommon p {
    font-size: 1.05rem;
    line-height: 1.65;
    color: #2a2a2a;
  }

  .notebook-wrapper .jp-RenderedMarkdown h1,
  .notebook-wrapper .jp-RenderedHTMLCommon h1 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: #111;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .notebook-wrapper .jp-RenderedMarkdown h2,
  .notebook-wrapper .jp-RenderedHTMLCommon h2 {
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    font-weight: 700;
    color: #111;
    margin-top: 3rem;
    margin-bottom: 0.5rem;
  }

  .notebook-wrapper .jp-RenderedMarkdown h3,
  .notebook-wrapper .jp-RenderedHTMLCommon h3 {
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    font-weight: 600;
    color: #222;
    margin-top: 2rem;
    margin-bottom: 0.4rem;
  }

  /* ── Code / pre font ────────────────────────────────────── */
  .notebook-wrapper pre,
  .notebook-wrapper code {
    font-family: "JetBrains Mono", "Menlo", "Monaco", "Courier New", monospace;
    font-size: 0.85rem;
  }

  /* ── Collapser elements — hidden ────────────────────────── */
  .notebook-wrapper .jp-Collapser {
    display: none;
  }

  /* ════════════════════════════════════════════════════════
     MOBILE OVERRIDES
     ════════════════════════════════════════════════════════ */
  @media (max-width: 768px) {
    /* Hero: full-bleed edge-to-edge on mobile */
    .datastory-header .post-hero {
      margin: 0 -1rem;
      width: calc(100% + 2rem);
    }

    /* Notebook images: near-full-bleed on mobile — photography primacy */
    .notebook-wrapper .jp-RenderedImage {
      margin-left: calc(-1 * (100vw - 100%) / 2 + 0.5rem);
      margin-right: calc(-1 * (100vw - 100%) / 2 + 0.5rem);
      width: calc(100vw - 1rem);
      max-width: calc(100vw - 1rem);
    }

    .notebook-wrapper .jp-RenderedImage img {
      width: 100%;
      max-width: 100%;
      border-radius: 0;
    }

    /* Tables: let them scroll naturally, don't crunch */
    .notebook-wrapper .jp-RenderedHTMLCommon {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .notebook-wrapper .jp-RenderedHTMLCommon table {
      min-width: 480px;
    }
  }

  /* ── Screen mode expansion ──────────────────────────────── */
  body.screen-mode .notebook-wrapper {
    max-width: 1100px;
  }
</style>
