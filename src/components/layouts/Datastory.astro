---
import { render, type CollectionEntry } from "astro:content";
import Lightbox from "../ui/Lightbox.astro";
import ScreenToggle from "../ui/ScreenToggle.astro";
import C2PAOverlay from "../ui/C2PAOverlay.astro";
import ContentsToggle from "../ui/ContentsToggle.astro";
import fs from "node:fs";
import path from "node:path";

interface Props {
  post: CollectionEntry<"datastory">;
}

const { post } = Astro.props;
const { Content } = await render(post);

const backgroundColor = post.data.backgroundColor || "var(--surface)";
const formattedDate = post.data.date?.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

let notebookHtml = "";
interface TocEntry { slug: string; text: string; }
const tocEntries: TocEntry[] = [];

const contentBase = path.resolve("src/content/datastory");
const htmlPath = path.join(contentBase, `${post.id}.notebook.html`);
if (fs.existsSync(htmlPath)) {
  notebookHtml = fs.readFileSync(htmlPath, "utf-8").trim();

  const h2Re = /<h2[^>]*id=["']([^"']*)["'][^>]*>(.*?)<\/h2>/gi;
  let match: RegExpExecArray | null;
  while ((match = h2Re.exec(notebookHtml)) !== null) {
    const slug = match[1];
    const text = match[2].replace(/<[^>]*>/g, "").replace(/\u00b6/g, "").trim();
    if (text) tocEntries.push({ slug, text });
  }
}
---

<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin="anonymous">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.38/dist/katex.min.css" integrity="sha384-/L6i+LN3dyoaK2jYG5ZLh5u13cjdsPDcFOSNJeFBFa/KgVXR5kOfTdiN3ft1uMAq" crossorigin="anonymous">
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.38/dist/katex.min.js" integrity="sha384-H6s1ZrH2CKpFpqR680poRdStIRJGXty7fSkxAcIfxwl9iu6A4BOPtTk7vQ58Ovio" crossorigin="anonymous"></script>
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.38/dist/contrib/auto-render.min.js" integrity="sha384-bjyGPfbij8/NDKJhSGZNP/khQVgtHUE5exjm4Ydllo42FwIgYsdLO2lXGmRBf5Mz" crossorigin="anonymous"></script>

<article class="datastory-layout" style={`--page-bg: ${backgroundColor};`}>
  <header class="post-header datastory-header">
    <div class="post-kicker">
      <span class="collection-type">Data Story</span>
    </div>
    <h1 class="post-title">{post.data.title}</h1>
    {post.data.subtitle && <p class="post-subtitle">{post.data.subtitle}</p>}
    <div class="post-author-line">
      <span class="by">By</span>
      <span class="author-name">{post.data.author}</span>
    </div>
    {formattedDate && (
      <div class="post-date-line">
        <time datetime={post.data.date?.toISOString()}>{formattedDate}</time>
      </div>
    )}
    {post.data.showhero !== false && post.data.heroImage && (
      <figure class="post-hero">
        <img src={post.data.heroImage} alt={post.data.title} />
      </figure>
    )}
  </header>

  <div class="datastory-container">
    {post.data.toc && tocEntries.length > 0 && (
      <ContentsToggle title={post.data.title}>
        <ul>
          {tocEntries.map((h) => (
            <li><a href={`#${h.slug}`}>{h.text}</a></li>
          ))}
        </ul>
      </ContentsToggle>
    )}

    <div class="datastory-prose">
      <Content />
    </div>

    {notebookHtml && (
      <div class="notebook-wrapper" set:html={notebookHtml} />
    )}
  </div>

  <Lightbox selector=".notebook-wrapper" gallery={post.data.lightbox?.gallery} />
  <ScreenToggle />
  <C2PAOverlay />
</article>

<script>
  function refineDatastoryContent() {
    const header = document.querySelector('.site-header') as HTMLElement;
    if (header) {
      header.style.backgroundColor = '#2a2a2a';
      header.style.transition = 'background-color 0.3s ease';
      const headerInner = header.querySelector('.site-header-inner') as HTMLElement;
      if (headerInner) headerInner.style.backgroundColor = 'transparent';
      header.querySelectorAll('a, button').forEach((el) => {
        (el as HTMLElement).style.color = '#fff';
      });
      header.querySelectorAll('.site-logo, .site-logo a').forEach((el) => {
        (el as HTMLElement).style.color = '#fff';
      });
    }
  }

  refineDatastoryContent();
  document.addEventListener('astro:page-load', refineDatastoryContent);

  function renderNotebookMath() {
    const wrapper = document.querySelector('.notebook-wrapper');
    if (!wrapper || typeof window.renderMathInElement !== 'function') return;
    window.renderMathInElement(wrapper as HTMLElement, {
      delimiters: [
        { left: "$$", right: "$$", display: true },
        { left: "$", right: "$", display: false },
        { left: "\\(", right: "\\)", display: false },
        { left: "\\[", right: "\\]", display: true },
      ],
      throwOnError: false,
    });
  }

  if (document.readyState === 'complete') {
    renderNotebookMath();
  } else {
    window.addEventListener('load', renderNotebookMath);
  }
  document.addEventListener('astro:page-load', () => {
    setTimeout(renderNotebookMath, 100);
  });
</script>

<style>
  .datastory-layout {
    width: 100%;
    min-height: 100vh;
    background: var(--page-bg, var(--surface));
  }

  .datastory-header {
    background: var(--paper);
    padding: 8rem 2rem 4rem;
    text-align: center;
  }

  .datastory-container {
    width: min(1200px, calc(100% - 2rem));
    margin: 0 auto;
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 2rem;
    padding: 3rem 0 5rem;
  }

  .datastory-prose,
  .notebook-wrapper {
    grid-column: 2;
  }

  .notebook-wrapper {
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
    box-sizing: border-box;
  }

  @media (max-width: 980px) {
    .datastory-container {
      grid-template-columns: 1fr;
    }

    .datastory-prose,
    .notebook-wrapper {
      grid-column: auto;
    }
  }
</style>
