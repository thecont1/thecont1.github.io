---
import { getCollection } from "astro:content";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import C2PAOverlay from "../../components/ui/C2PAOverlay.astro";
import { AUTHOR } from "../../data/author";
import "../../styles/fonts.css";
import "../../styles/global.css";
import "../../styles/header.css";
import "../../styles/footer.css";

const codeProjects = await getCollection("code", ({ data }) => data.status === "published");

const title = "Code Projects | Mahesh Shantaram";
const description = "Open source projects and creative coding experiments by Mahesh Shantaram.";
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(AUTHOR.image, Astro.site).href;

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: AUTHOR.name,
  url: AUTHOR.url,
  jobTitle: AUTHOR.jobTitle,
  sameAs: AUTHOR.sameAs,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Mahesh Shantaram" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@thecontrarian" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
  </head>

  <body>
    <canvas id="snow-canvas" aria-hidden="true"></canvas>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <SiteHeader />
    
    <main id="main-content" class="code-index" tabindex="-1">
      <header class="page-header">
        <h1>Code Projects</h1>
        <p>Open source projects and creative coding experiments</p>
      </header>

      <div class="projects-grid">
        {codeProjects.map((project) => (
          <article class="project-card">
            <a href={`/code/${project.id}`}>
              <div class="card-header">
                <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor" class="github-icon">
                  <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
                </svg>
                <h2>{project.data.repoOwner}/{project.data.repoName}</h2>
              </div>
              
              <p class="description">{project.data.description}</p>
              
              <div class="project-meta">
                {project.data.language && <span class="language">{project.data.language}</span>}
                {project.data.stars !== undefined && project.data.stars > 0 && <span class="stars">⭐ {project.data.stars}</span>}
                {project.data.license && <span class="license">{project.data.license}</span>}
              </div>
              
              {project.data.tags && project.data.tags.length > 0 && (
                <div class="tags">
                  {project.data.tags.slice(0, 3).map(tag => (
                    <span class="tag">#{tag}</span>
                  ))}
                </div>
              )}
            </a>
          </article>
        ))}
      </div>
    </main>

    <SiteFooter />
    <C2PAOverlay />
    <script is:inline src="/textmode.js" defer></script>
    <script is:inline src="/snow-loader.js" defer></script>
    <script is:inline src="/mobile-nav.js" defer></script>
  </body>
</html>

<style>
  .code-index {
    max-width: 1200px;
    margin: 0 auto;
    padding: 8rem 2rem 4rem;
  }
</style>
