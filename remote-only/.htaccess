RewriteEngine On

# Redirect legacy sitemap URLs to the generated sitemap index.
RewriteRule ^sitemap\.xml$ /sitemap-index.xml [R=301,L]

# Redirect all /library/** requests to the CDN origin.
# The Cloudflare Worker on library.thecontrarian.in handles lightbox-vs-raw-image routing.
RewriteCond %{HTTP_HOST} ^(www\.)?thecontrarian\.in$ [NC]
RewriteRule ^library/(.*)$ https://library.thecontrarian.in/$1 [R=301,L,NC,NE]

# HTML should always revalidate to avoid old pages referencing pruned hashed assets.
<IfModule mod_headers.c>
  <FilesMatch "\.(html?|xhtml)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
    Header set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; frame-src 'none'; script-src 'self' 'unsafe-inline' 'report-sample' https://cdn.jsdelivr.net; script-src-attr 'none'; style-src 'self' 'unsafe-inline' 'report-sample' https://cdn.jsdelivr.net; img-src 'self' data: blob: https://library.thecontrarian.in https://apps.thecontrarian.in; font-src 'self' data: https://cdn.jsdelivr.net; connect-src 'self' https://apps.thecontrarian.in; manifest-src 'self'; worker-src 'self' blob:"
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
  </FilesMatch>
</IfModule>
